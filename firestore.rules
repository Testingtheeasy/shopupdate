rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // IMPORTANT: replace ADMIN_EMAIL_PLACEHOLDER below with your real admin
    // email before publishing these rules — this is the one account allowed
    // to approve/reject pending shop claims from the admin panel.
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'goodwingowthamraj333@gmail.com';
    }

    match /shops/{shopId} {
      allow read: if true;
      // Owner can create/update their own shop (ownerId == their uid).
      // Admin can update any shop (needed to approve/reject verification).
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /owners/{ownerId} {
      allow read: if true;
      // Owner doc ID is now always the Firebase Auth UID — an owner can
      // create their own record and update only shopPlaceId/fcmToken.
      allow create: if request.auth != null && request.auth.uid == ownerId;
      allow update: if request.auth != null && request.auth.uid == ownerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['shopPlaceId', 'fcmToken']);
      allow delete: if false;
    }
  }
}

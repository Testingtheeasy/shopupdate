rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /shops/{shopId} {
      allow read: if true;
      allow create, update: if request.auth != null && isMatchingOwner(request.resource.data.ownerId);
    }

    match /owners/{ownerId} {
      allow read: if true;
      allow create, delete: if false;
      // Owner can update shopPlaceId (claim flow) and their own fcmToken
      // (notification registration) — nothing else, ever, from the client.
      allow update: if request.auth != null
        && isMatchingOwner(ownerId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['shopPlaceId', 'fcmToken']);
    }

    function isMatchingOwner(ownerId) {
      let o = get(/databases/$(database)/documents/owners/$(ownerId)).data;
      let tokenEmail = request.auth.token.email.lower();
      return (('email' in o) && o.email.lower() == tokenEmail)
          || (('phone' in o) && (o.phone + '@shopstatus-users.app') == tokenEmail);
    }
  }
}
